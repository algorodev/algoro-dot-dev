---
type Variant = 'primary' | 'secondary';

type Props = {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: Variant;
  arrow?: string;
  class?: string;
};

const {
  href,
  type = 'button',
  variant = 'primary',
  arrow,
  class: className = '',
} = Astro.props;

const base =
  'group inline-flex items-center gap-2.5 rounded-md border border-transparent px-[22px] py-[14px] font-mono text-[13px] font-medium transition-all duration-200 cursor-pointer active:scale-[0.98]';

const variants: Record<Variant, string> = {
  primary: 'bg-accent text-[#0a0a0a] hover:-translate-y-px hover:bg-[#d9ff5d]',
  secondary:
    'border-border-strong text-fg hover:-translate-y-px hover:border-fg-muted hover:bg-bg-elevated',
};

const cls = `${base} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={cls}>
      <slot />
      {arrow && (
        <span class="font-mono transition-transform duration-200 group-hover:translate-x-[3px]">
          {arrow}
        </span>
      )}
    </a>
  ) : (
    <button type={type} class={cls}>
      <slot />
      {arrow && (
        <span class="font-mono transition-transform duration-200 group-hover:translate-x-[3px]">
          {arrow}
        </span>
      )}
    </button>
  )
}
