---
import StackTag from '@components/ui/StackTag.astro';

type Props = {
  href: string;
  tag: string;
  period: string;
  title: string;
  description: string;
  stack: string[];
  linkLabel?: string;
  featured?: boolean;
};

const {
  href,
  tag,
  period,
  title,
  description,
  stack,
  linkLabel = 'Read case study',
  featured = false,
} = Astro.props;
---

<a
  href={href}
  class:list={[
    'group relative block overflow-hidden rounded-xl border p-10 transition-all duration-300',
    'border-[var(--layer-surface-border)] bg-white',
    'hover:-translate-y-0.5 hover:border-[var(--layer-surface-accent)]',
    featured && 'sm:col-span-2',
  ]}
>
  <div
    class="mb-8 flex justify-between font-mono text-[11px] tracking-[0.05em] uppercase"
    style="color: var(--layer-surface-muted);"
  >
    <span style="color: var(--layer-surface-accent);">● {tag}</span>
    <span>{period}</span>
  </div>
  <h3
    class:list={[
      'mb-4 font-serif font-normal leading-[1.1] tracking-[-0.02em]',
      featured ? 'text-[44px]' : 'text-[32px]',
    ]}
  >
    <Fragment set:html={title} />
  </h3>
  <p class="mb-8 max-w-[560px] text-[15px] leading-relaxed" style="color: var(--layer-surface-muted);">
    {description}
  </p>
  {
    stack.length > 0 && (
      <div class="mb-6 flex flex-wrap gap-2">
        {stack.map((s) => (
          <StackTag class="wc-surface-tag">{s}</StackTag>
        ))}
      </div>
    )
  }
  <span
    class="inline-flex items-center gap-1.5 border-b border-transparent pb-0.5 font-mono text-xs transition-colors duration-200 group-hover:border-[var(--layer-surface-accent)]"
    style="color: var(--layer-surface-accent);"
  >
    {linkLabel} <span>→</span>
  </span>
</a>

<style is:global>
  [data-layer="surface"] .wc-surface-tag {
    border-color: color-mix(in srgb, var(--layer-surface-accent) 25%, transparent);
    background-color: color-mix(in srgb, var(--layer-surface-accent) 8%, transparent);
    color: var(--layer-surface-accent);
  }
</style>
