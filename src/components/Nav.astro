---
const pathname = new URL(Astro.request.url).pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');

const links = [
  { href: '/work', label: 'work' },
  { href: '/#demo', label: 'ai/demo' },
  { href: '/about', label: 'about' },
  { href: '/contact', label: 'contact' },
];
---

<nav
  class="sticky top-0 z-50 border-b border-border py-2 backdrop-blur-md"
  style="background-color: color-mix(in srgb, var(--nav-bg) 70%, transparent); color: var(--nav-text); transition: var(--layer-transition);"
>
  <div class="container-x flex items-center justify-between">
    <a
      href="/"
      class="logo-home"
      aria-label="algorodev home"
      style="color: var(--nav-accent);"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 192 192"
        aria-hidden="true"
        class="logo-icon"
      >
        <rect x="49" y="49" width="22" height="22" fill="currentColor"/>
        <rect x="73" y="49" width="22" height="22" fill="currentColor"/>
        <rect x="97" y="49" width="22" height="22" fill="currentColor"/>
        <rect x="121" y="73" width="22" height="22" fill="currentColor"/>
        <rect x="49" y="97" width="22" height="22" fill="currentColor"/>
        <rect x="73" y="97" width="22" height="22" fill="currentColor"/>
        <rect x="97" y="97" width="22" height="22" fill="currentColor"/>
        <rect x="121" y="97" width="22" height="22" fill="currentColor"/>
        <rect x="25" y="121" width="22" height="22" fill="currentColor"/>
        <rect x="121" y="121" width="22" height="22" fill="currentColor"/>
        <rect x="49" y="145" width="22" height="22" fill="currentColor"/>
        <rect x="73" y="145" width="22" height="22" fill="currentColor"/>
        <rect x="97" y="145" width="22" height="22" fill="currentColor"/>
        <rect x="25" y="169" width="22" height="22" fill="currentColor"/>
        <rect x="49" y="169" width="22" height="22" fill="currentColor"/>
        <rect x="73" y="169" width="22" height="22" fill="currentColor"/>
        <rect x="97" y="169" width="22" height="22" fill="currentColor"/>
      </svg>
    </a>
    <ul class="hidden gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'nav-link font-mono text-[13px]',
                isActive(link.href) ? '' : 'nav-link-inactive',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="hidden items-center gap-5 md:flex">
      <span
        id="nav-depth"
        class="font-mono text-xs"
        style="color: var(--nav-accent);"
      >depth: 01 · surface</span>
      <div class="flex items-center gap-2 font-mono text-xs opacity-60">
        <span class="status-dot"></span>
        <span>available · q2 2026</span>
      </div>
    </div>
  </div>
</nav>

<style>
  .logo-home {
    display: flex;
    align-items: center;
    transition: color 0.3s ease;
  }
  .logo-home:hover {
    opacity: 0.75;
  }
  .logo-icon {
    height: 2.5rem;
    width: auto;
  }
  nav svg {
    transition: color 0.3s ease;
  }
  .nav-link {
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }
  .nav-link-inactive {
    opacity: 0.6;
  }
  .nav-link:hover {
    color: var(--nav-accent);
    opacity: 1;
  }
</style>
