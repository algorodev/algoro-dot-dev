---
const pathname = new URL(Astro.request.url).pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');

const links = [
  { href: '/work', label: 'work' },
  { href: '/#demo', label: 'ai/demo' },
  { href: '/about', label: 'about' },
  { href: '/contact', label: 'contact' },
];
---

<nav
  class="sticky top-0 z-50 border-b border-border py-4 backdrop-blur-md"
  style="background-color: color-mix(in srgb, var(--nav-bg) 70%, transparent); color: var(--nav-text); transition: var(--layer-transition);"
>
  <div class="container-x flex items-center justify-between">
    <a
      href="/"
      class="font-mono text-sm font-medium tracking-tight"
      aria-label="algorodev home"
    >
      algoro<svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 4 12"
        aria-hidden="true"
        class="mx-[2px] inline-block h-[0.85em] w-[0.28em] animate-pulse align-[-0.05em]"
        style="color: var(--nav-accent);"
      ><rect width="4" height="12" rx="0.4" fill="currentColor" /></svg>dev
    </a>
    <ul class="hidden gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'nav-link font-mono text-[13px]',
                isActive(link.href) ? '' : 'nav-link-inactive',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="hidden items-center gap-5 md:flex">
      <span
        id="nav-depth"
        class="font-mono text-xs"
        style="color: var(--nav-accent);"
      >depth: 01 · surface</span>
      <div class="flex items-center gap-2 font-mono text-xs opacity-60">
        <span class="status-dot"></span>
        <span>available · q2 2026</span>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-link {
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }
  .nav-link-inactive {
    opacity: 0.6;
  }
  .nav-link:hover {
    color: var(--nav-accent);
    opacity: 1;
  }
</style>
