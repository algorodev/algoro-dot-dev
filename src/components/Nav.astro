---
const pathname = new URL(Astro.request.url).pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');

const links = [
  { href: '/work', label: 'work' },
  { href: '/#demo', label: 'ai/demo' },
  { href: '/about', label: 'about' },
  { href: '/contact', label: 'contact' },
];
---

<nav class="sticky top-0 z-50 border-b border-border bg-bg/70 py-4 backdrop-blur-md">
  <div class="container-x flex items-center justify-between">
    <a
      href="/"
      class="font-mono text-sm font-medium tracking-tight text-fg"
      aria-label="algorodev — home"
    >
      algoro<span class="text-accent" aria-hidden="true">▍</span>dev
    </a>
    <ul class="hidden gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'font-mono text-[13px] transition-colors hover:text-fg',
                isActive(link.href) ? 'text-fg' : 'text-fg-muted',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="hidden items-center gap-2 font-mono text-xs text-fg-muted md:flex">
      <span class="status-dot"></span>
      <span>available · q2 2026</span>
    </div>
  </div>
</nav>
