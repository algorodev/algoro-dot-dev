---
type Props = {
  number: string;
  title: string;
  meta?: string;
  id?: string;
};

const { number, title, meta, id } = Astro.props;
---

<div id={id} class="mb-14 flex items-baseline gap-6 border-b border-border pb-6">
  <div class="font-mono text-xs tracking-[0.1em] text-fg-faded">{number}</div>
  <h2 class="flex-1 font-serif text-[36px] leading-tight font-normal tracking-tight">
    {title}
  </h2>
  {meta && <div class="font-mono text-xs text-fg-faded">{meta}</div>}
</div>
