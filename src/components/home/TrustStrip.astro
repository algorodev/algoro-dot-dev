---
import Section from '@components/Section.astro';

const logos = ['Mercedes-Benz', 'Smartbox', 'Nexook', 'Prozeso'];
---

<Section
  number="trust"
  eyebrow="teams"
  meta="+15 via prozeso"
>
  <div class="flex flex-wrap items-center gap-x-14 gap-y-6">
    {
      logos.map((logo) => (
        <div class="cursor-default font-serif text-[28px] italic text-fg-muted opacity-70 transition-[color,opacity] duration-300 hover:text-fg hover:opacity-100">
          {logo}
        </div>
      ))
    }
  </div>
</Section>
