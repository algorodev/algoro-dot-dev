---
import Button from '@components/ui/Button.astro';
---

<div class="hero-section container-x">
  <div class="hero-rule" aria-hidden="true"></div>

  <h1
    id="hero-title"
    class="hero-headline font-serif font-normal leading-[0.95] tracking-[-0.03em]"
  >
    Full-stack runs <em style="color: var(--layer-surface-accent);" class="italic">deep.</em>
  </h1>

  <p class="hero-tagline">
    Frontend to infra.<br />
    <span style="color: var(--layer-surface-accent);">Scroll to explore the stack.</span>
  </p>

  <p class="hero-bio">
    Senior software engineer with <strong class="font-medium">nearly 8 years</strong> shipping
    production systems across enterprise (Mercedes-Benz), scale-ups (Smartbox), and startups.
    Hands-on with AI/ML in production since 2022. Currently CTO &amp; co-founder at Prozeso.
  </p>

  <div class="hero-ctas">
    <Button href="/contact" variant="primary" arrow="→">Hire me</Button>
    <Button href="#work" variant="secondary" arrow="→">View selected work</Button>
  </div>
</div>

<style>
  .hero-section {
    padding-top: 140px;
    padding-bottom: 120px;
  }
  .hero-rule {
    width: 48px;
    height: 2px;
    margin-bottom: 48px;
    background-color: var(--layer-surface-accent);
  }
  .hero-headline {
    font-size: clamp(52px, 8.5vw, 120px);
    max-width: 14ch;
    margin-bottom: 32px;
  }
  .hero-tagline {
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.45;
    margin-bottom: 40px;
    max-width: 560px;
    color: var(--layer-surface-muted);
  }
  .hero-bio {
    font-size: 16px;
    line-height: 1.65;
    max-width: 620px;
    color: var(--layer-surface-muted);
    margin-bottom: 48px;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
  }
  @media (max-width: 900px) {
    .hero-section {
      padding-top: 80px;
      padding-bottom: 72px;
    }
  }
</style>

<script>
  const title = document.getElementById('hero-title');
  if (title) {
    const fragments: ChildNode[] = Array.from(title.childNodes);
    title.classList.add('word-stagger');
    title.innerHTML = '';
    let idx = 0;
    for (const node of fragments) {
      if (node.nodeType === Node.TEXT_NODE) {
        const text = node.textContent ?? '';
        const parts = text.split(/(\s+)/);
        for (const part of parts) {
          if (part === '') continue;
          if (/^\s+$/.test(part)) {
            title.appendChild(document.createTextNode(part));
          } else {
            const span = document.createElement('span');
            span.textContent = part;
            span.style.animationDelay = `${idx * 60}ms`;
            title.appendChild(span);
            idx++;
          }
        }
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        const el = node as HTMLElement;
        if (el.tagName === 'BR') {
          title.appendChild(document.createElement('br'));
          continue;
        }
        const text = el.textContent ?? '';
        const parts = text.split(/(\s+)/);
        for (const part of parts) {
          if (part === '') continue;
          if (/^\s+$/.test(part)) {
            title.appendChild(document.createTextNode(part));
          } else {
            const span = document.createElement('span');
            span.textContent = part;
            span.className = el.className;
            const tag = el.tagName.toLowerCase();
            if (tag === 'em') span.style.fontStyle = 'italic';
            if (el.style.color) span.style.color = el.style.color;
            span.style.animationDelay = `${idx * 60}ms`;
            title.appendChild(span);
            idx++;
          }
        }
      }
    }
  }
</script>
