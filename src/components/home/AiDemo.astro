---
import Section from '@components/Section.astro';

const stack = [
  'Gemini 2.5 Flash · streaming',
  'Gemini embeddings · gemini-embedding-001',
  'In-memory cosine · top-5 retrieval',
  'Inline [N] citations · linked sources',
  'Vercel · on-demand Astro route',
];

const suggested = [
  'What is Otto?',
  "What's the stack at Prozeso?",
  'Tell me about the Smartbox voice work',
];
---

<Section id="demo" number="/02" eyebrow="live ai demo" meta="rag · streaming · cited">
  <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-[1fr_1.4fr] lg:gap-16">
    <div>
      <h3
        class="mb-6 font-serif text-[44px] leading-none font-normal tracking-[-0.02em]"
      >
        Ask the <em class="text-accent italic">portfolio</em> anything.
      </h3>
      <p class="mb-6 text-[15px] text-fg-muted">
        This isn't a static page — it's a working RAG system over my CV, case studies, and writing.
        Ask anything about my experience and the system retrieves relevant chunks, generates a
        grounded answer, and cites the source.
      </p>
      <p class="mb-6 text-[13px] text-fg-faded">
        Same architecture I ship to clients. No mock data, no canned responses.
      </p>
      <div class="mt-8 border-t border-border pt-6">
        <div
          class="mb-3 font-mono text-[11px] tracking-[0.1em] text-fg-faded uppercase"
        >
          — stack
        </div>
        <ul class="font-mono text-xs leading-[1.9] text-fg-muted">
          {
            stack.map((line) => (
              <li>
                <span class="text-accent-dim">→</span> {line}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      data-chat
      class="overflow-hidden rounded-xl border border-border bg-bg-elevated"
    >
      <div
        class="flex items-center gap-2.5 border-b border-border px-5 py-3.5 font-mono text-xs text-fg-muted"
      >
        <div class="flex gap-1.5">
          <span class="h-2.5 w-2.5 rounded-full bg-border-strong"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-border-strong"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-border-strong"></span>
        </div>
        <span class="ml-2">algoro.rag — interactive</span>
      </div>

      <div class="flex min-h-[380px] flex-col gap-4 p-6">
        <div data-empty class="flex flex-1 flex-col items-start justify-center gap-2 text-fg-faded">
          <p class="text-[14px] leading-[1.55]">
            Ask anything about Alejandro's work, projects, or experience. Answers stream live and
            cite the source.
          </p>
        </div>

        <div data-messages class="flex flex-col gap-4"></div>

        <div data-suggested class="mt-auto flex flex-wrap gap-2">
          {
            suggested.map((q) => (
              <button
                type="button"
                data-q={q}
                class="cursor-pointer rounded-full border border-border bg-transparent px-3 py-1.5 font-mono text-[11px] text-fg-muted transition-all duration-200 hover:border-accent-dim hover:text-accent"
              >
                → {q}
              </button>
            ))
          }
        </div>
      </div>

      <div class="flex items-center gap-3 border-t border-border px-5 py-3.5">
        <input
          data-input
          type="text"
          aria-label="Ask anything about my work"
          placeholder="Ask anything about my work..."
          class="flex-1 border-0 bg-transparent font-sans text-sm text-fg outline-none placeholder:text-fg-faded disabled:opacity-50"
        />
        <button
          data-send
          type="button"
          class="cursor-pointer rounded border border-accent-dim bg-transparent px-3 py-1.5 font-mono text-[11px] text-accent transition-colors hover:bg-accent/10 disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:bg-transparent"
        >
          send ↵
        </button>
      </div>
    </div>
  </div>
</Section>

<script>
  type SourceRef = {
    n: number;
    title: string;
    section: string;
    url: string;
    score: number;
  };

  type Message = {
    role: 'user' | 'assistant';
    content: string;
    sources?: SourceRef[];
    error?: boolean;
  };

  const root = document.querySelector<HTMLElement>('[data-chat]');
  if (root) {
    const messagesEl = root.querySelector<HTMLElement>('[data-messages]')!;
    const emptyEl = root.querySelector<HTMLElement>('[data-empty]')!;
    const suggestedEl = root.querySelector<HTMLElement>('[data-suggested]')!;
    const inputEl = root.querySelector<HTMLInputElement>('[data-input]')!;
    const sendBtn = root.querySelector<HTMLButtonElement>('[data-send]')!;

    const messages: Message[] = [];
    let isStreaming = false;

    const escapeHtml = (s: string): string =>
      s.replace(
        /[&<>"']/g,
        (c) =>
          ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!,
      );

    function renderText(text: string, sources?: SourceRef[]): string {
      let html = escapeHtml(text);
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-fg">$1</strong>');
      html = html.replace(
        /`([^`]+)`/g,
        '<code class="rounded bg-white/5 px-1 py-px font-mono text-[12px]">$1</code>',
      );
      html = html.replace(/\[(\d+)\]/g, (match, n: string) => {
        const src = sources?.find((s) => s.n === Number(n));
        if (!src) return match;
        const label = `${src.title}${src.section !== 'header' ? ' · ' + src.section : ''}`;
        return `<a href="${src.url}" title="${escapeHtml(label)}" class="mx-0.5 inline-block cursor-pointer rounded-[3px] border border-accent/20 bg-accent/10 px-1.5 py-px font-mono text-[10px] text-accent hover:bg-accent/20">[${n}]</a>`;
      });
      return html;
    }

    function render() {
      const hasMessages = messages.length > 0;
      emptyEl.style.display = hasMessages ? 'none' : 'flex';
      suggestedEl.style.display = hasMessages || isStreaming ? 'none' : 'flex';

      messagesEl.innerHTML = messages
        .map((m, i) => {
          const isLast = i === messages.length - 1;
          if (m.role === 'user') {
            return `<div class="max-w-[85%] self-end rounded-[10px] bg-accent px-4 py-3 font-medium text-bg" style="font-size: 14px; line-height: 1.55;">${escapeHtml(m.content)}</div>`;
          }
          const cursor =
            isStreaming && isLast
              ? '<span class="ml-0.5 inline-block animate-pulse text-accent">▋</span>'
              : '';
          const errClass = m.error ? ' italic text-fg-faded' : '';
          const body = m.content
            ? renderText(m.content, m.sources)
            : '<span class="animate-pulse text-accent">▋</span>';
          return `<div class="max-w-[85%] self-start rounded-[10px] border border-border bg-white/[0.03] px-4 py-3 text-fg${errClass}" style="font-size: 14px; line-height: 1.55;">${body}${m.content ? cursor : ''}</div>`;
        })
        .join('');

      inputEl.disabled = isStreaming;
      sendBtn.disabled = isStreaming;
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    async function send(text: string) {
      const trimmed = text.trim();
      if (!trimmed || isStreaming) return;

      messages.push({ role: 'user', content: trimmed });
      messages.push({ role: 'assistant', content: '' });
      isStreaming = true;
      render();

      const last = messages[messages.length - 1];
      const ctrl = new AbortController();

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            messages: messages
              .slice(0, -1)
              .map((m) => ({ role: m.role, content: m.content })),
          }),
          signal: ctrl.signal,
        });

        if (!res.ok || !res.body) {
          let msg = `Request failed (${res.status}).`;
          try {
            const j = await res.json();
            if (j?.error) msg = j.error;
          } catch {
            /* ignore */
          }
          last.content = msg;
          last.error = true;
          return;
        }

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() ?? '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            let event: { type: string; [k: string]: unknown };
            try {
              event = JSON.parse(line.slice(6));
            } catch {
              continue;
            }
            if (event.type === 'sources') {
              last.sources = event.sources as SourceRef[];
            } else if (event.type === 'text') {
              last.content += event.text as string;
            } else if (event.type === 'error') {
              last.content = (event.error as string) || 'Something went wrong.';
              last.error = true;
            }
            render();
          }
        }
      } catch (err) {
        const isAbort = err instanceof DOMException && err.name === 'AbortError';
        if (!isAbort) {
          last.content = err instanceof Error ? err.message : 'Network error.';
          last.error = true;
        }
      } finally {
        isStreaming = false;
        render();
        inputEl.focus();
      }
    }

    sendBtn.addEventListener('click', () => {
      const v = inputEl.value;
      inputEl.value = '';
      send(v);
    });

    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        const v = inputEl.value;
        inputEl.value = '';
        send(v);
      }
    });

    suggestedEl.querySelectorAll<HTMLButtonElement>('[data-q]').forEach((btn) => {
      btn.addEventListener('click', () => send(btn.dataset.q ?? ''));
    });

    render();
  }
</script>
