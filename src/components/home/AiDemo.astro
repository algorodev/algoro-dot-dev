---
import Section from '@components/Section.astro';

const stack = [
  'Gemini 2.5 Flash · streaming',
  'Gemini embeddings · gemini-embedding-001',
  'In-memory cosine · top-5 retrieval',
  'Inline [N] citations · linked sources',
  'Vercel · on-demand Astro route',
];

const suggested = [
  'What is Otto?',
  "What's the stack at Prozeso?",
  'Tell me about the Smartbox voice work',
];
---

<Section id="demo" number="/06" eyebrow="void.rag" meta="depth 04 · bottom">
  <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-[1fr_1.4fr] lg:gap-16">
    <div>
      <div class="void-layer-tag">Layer 04 · AI / LLMs / RAG</div>
      <h3 class="void-heading">This is where it thinks.</h3>
      <p class="void-desc">
        You've scrolled through the full stack. This is the bottom. A working RAG system over my
        CV, case studies, and writing — same architecture I ship to clients. Ask anything.
      </p>
      <div class="void-syslog">
        <div class="void-syslog-label">sys.log</div>
        <ul class="void-syslog-list">
          {
            stack.map((line) => (
              <li>
                <span class="void-arrow">→</span>
                {line}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="void-right">
      <div class="void-grid-bg" aria-hidden="true"></div>

      <div data-chat class="void-chat">
        <div class="void-titlebar">
          <div class="void-titlebar-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <span>algoro.rag · interactive</span>
        </div>

        <div class="void-body">
          <div data-empty class="void-empty">
            <p>
              Ask anything about Alejandro's work, projects, or experience. Answers stream live
              and cite the source.
            </p>
          </div>

          <div data-messages class="flex flex-col gap-4"></div>

          <div data-suggested class="mt-auto flex flex-wrap gap-2">
            {
              suggested.map((q) => (
                <button type="button" data-q={q} class="void-chip">→ {q}</button>
              ))
            }
          </div>
        </div>

        <div class="void-input-row">
          <input
            data-input
            type="text"
            aria-label="Ask anything about my work"
            placeholder="Ask anything about my work..."
            class="void-input"
          />
          <button data-send type="button" class="void-send">send ↵</button>
        </div>
      </div>
    </div>
  </div>
</Section>

<style is:global>
  #demo {
    border-top-color: var(--layer-void-border);
  }
  #demo .section-rail {
    color: var(--layer-void-muted);
    border-color: var(--layer-void-border);
  }
  #demo .rail-num {
    color: var(--layer-void-accent);
  }
  #demo .rail-eyebrow {
    color: var(--layer-void-text);
  }
  #demo .rail-meta,
  #demo .rail-note {
    color: var(--layer-void-muted);
  }
  #demo .rail-divider {
    background: var(--layer-void-border);
  }
  @media (max-width: 900px) {
    #demo .section-rail {
      border-bottom-color: var(--layer-void-border);
    }
  }

  /* dynamically created message elements */
  .void-msg-user {
    max-width: 85%;
    align-self: flex-end;
    background: var(--layer-void-accent);
    color: white;
    padding: 12px 16px;
    font-size: 14px;
    line-height: 1.55;
    font-weight: 500;
    border-radius: 2px;
  }
  .void-msg-bot {
    max-width: 85%;
    align-self: flex-start;
    background: color-mix(in srgb, var(--layer-void-accent) 6%, transparent);
    border: 1px solid var(--layer-void-border);
    color: var(--layer-void-text);
    padding: 12px 16px;
    font-size: 14px;
    line-height: 1.55;
    border-radius: 2px;
  }
  .void-msg-error {
    color: var(--layer-void-muted);
    font-style: italic;
  }
  .void-cite {
    display: inline-block;
    border: 1px solid color-mix(in srgb, var(--layer-void-accent) 25%, transparent);
    background: color-mix(in srgb, var(--layer-void-accent) 12%, transparent);
    color: var(--layer-void-accent);
    border-radius: 3px;
    padding: 0 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    margin: 0 2px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .void-cite:hover {
    background: color-mix(in srgb, var(--layer-void-accent) 22%, transparent);
  }
  .void-cursor {
    color: var(--layer-void-accent);
    display: inline-block;
    margin-left: 2px;
    animation: void-cursor-blink 1.2s ease infinite;
  }
  @keyframes void-cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.2;
    }
  }
</style>

<style>
  /* left column */
  .void-layer-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--layer-void-accent);
    margin-bottom: 16px;
  }
  .void-heading {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--layer-void-text);
    margin-bottom: 20px;
  }
  .void-desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--layer-void-text);
    max-width: 60ch;
    margin-bottom: 32px;
    opacity: 0.85;
  }
  .void-syslog {
    border-top: 1px solid var(--layer-void-border);
    padding-top: 20px;
  }
  .void-syslog-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--layer-void-muted);
    margin-bottom: 10px;
  }
  .void-syslog-list {
    list-style: none;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 2;
    color: var(--layer-void-muted);
  }
  .void-arrow {
    color: var(--layer-void-accent);
    margin-right: 6px;
  }

  /* right column — grid + chat */
  .void-right {
    position: relative;
  }
  .void-grid-bg {
    position: absolute;
    inset: -24px;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(
        to right,
        color-mix(in srgb, var(--layer-void-accent) 4%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        to bottom,
        color-mix(in srgb, var(--layer-void-accent) 4%, transparent) 1px,
        transparent 1px
      );
    background-size: 32px 32px;
  }
  .void-chat {
    position: relative;
    z-index: 1;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid color-mix(in srgb, var(--layer-void-accent) 30%, transparent);
    background: color-mix(in srgb, var(--layer-void-bg) 60%, transparent);
    backdrop-filter: blur(8px);
  }
  .void-titlebar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    border-bottom: 1px solid var(--layer-void-border);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--layer-void-muted);
    background: color-mix(in srgb, var(--layer-void-bg) 80%, transparent);
  }
  .void-titlebar-dots {
    display: flex;
    gap: 5px;
  }
  .void-titlebar-dots span {
    display: block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--layer-void-border);
  }
  .void-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 380px;
    padding: 24px;
  }
  .void-empty {
    flex: 1;
    display: flex;
    align-items: center;
    font-size: 14px;
    line-height: 1.55;
    color: var(--layer-void-muted);
  }
  .void-chip {
    cursor: pointer;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--layer-void-accent) 40%, transparent);
    background: transparent;
    padding: 6px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--layer-void-muted);
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .void-chip:hover {
    background: var(--layer-void-accent);
    color: white;
    border-color: var(--layer-void-accent);
  }
  .void-input-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    border-top: 1px solid var(--layer-void-border);
  }
  .void-input {
    flex: 1;
    background: transparent;
    border: 1px solid var(--layer-void-border);
    border-radius: 0;
    color: var(--layer-void-text);
    font-family: var(--font-sans);
    font-size: 14px;
    padding: 6px 12px;
    outline: none;
  }
  .void-input::placeholder {
    color: var(--layer-void-muted);
  }
  .void-input:disabled {
    opacity: 0.5;
  }
  .void-send {
    cursor: pointer;
    flex-shrink: 0;
    background: var(--layer-void-accent);
    color: white;
    border: none;
    border-radius: 0;
    padding: 7px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    transition: opacity 0.2s ease;
  }
  .void-send:hover:not(:disabled) {
    opacity: 0.85;
  }
  .void-send:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }
</style>

<script>
  type SourceRef = {
    n: number;
    title: string;
    section: string;
    url: string;
    score: number;
  };

  type Message = {
    role: 'user' | 'assistant';
    content: string;
    sources?: SourceRef[];
    error?: boolean;
  };

  const root = document.querySelector<HTMLElement>('[data-chat]');
  if (root) {
    const messagesEl = root.querySelector<HTMLElement>('[data-messages]')!;
    const emptyEl = root.querySelector<HTMLElement>('[data-empty]')!;
    const suggestedEl = root.querySelector<HTMLElement>('[data-suggested]')!;
    const inputEl = root.querySelector<HTMLInputElement>('[data-input]')!;
    const sendBtn = root.querySelector<HTMLButtonElement>('[data-send]')!;

    const messages: Message[] = [];
    let isStreaming = false;

    const escapeHtml = (s: string): string =>
      s.replace(
        /[&<>"']/g,
        (c) =>
          ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!,
      );

    function renderText(text: string, sources?: SourceRef[]): string {
      let html = escapeHtml(text);
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-fg">$1</strong>');
      html = html.replace(
        /`([^`]+)`/g,
        '<code class="rounded bg-white/5 px-1 py-px font-mono text-[12px]">$1</code>',
      );
      html = html.replace(/\[(\d+)\]/g, (match, n: string) => {
        const src = sources?.find((s) => s.n === Number(n));
        if (!src) return match;
        const label = `${src.title}${src.section !== 'header' ? ' · ' + src.section : ''}`;
        return `<a href="${src.url}" title="${escapeHtml(label)}" class="void-cite">[${n}]</a>`;
      });
      return html;
    }

    function render() {
      const hasMessages = messages.length > 0;
      emptyEl.style.display = hasMessages ? 'none' : 'flex';
      suggestedEl.style.display = hasMessages || isStreaming ? 'none' : 'flex';

      messagesEl.innerHTML = messages
        .map((m, i) => {
          const isLast = i === messages.length - 1;
          if (m.role === 'user') {
            return `<div class="void-msg-user">${escapeHtml(m.content)}</div>`;
          }
          const cursor =
            isStreaming && isLast ? '<span class="void-cursor">▋</span>' : '';
          const errClass = m.error ? ' void-msg-error' : '';
          const body = m.content
            ? renderText(m.content, m.sources)
            : '<span class="void-cursor">▋</span>';
          return `<div class="void-msg-bot${errClass}">${body}${m.content ? cursor : ''}</div>`;
        })
        .join('');

      inputEl.disabled = isStreaming;
      sendBtn.disabled = isStreaming;
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    async function send(text: string) {
      const trimmed = text.trim();
      if (!trimmed || isStreaming) return;

      messages.push({ role: 'user', content: trimmed });
      messages.push({ role: 'assistant', content: '' });
      isStreaming = true;
      render();

      const last = messages[messages.length - 1];
      const ctrl = new AbortController();

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            messages: messages
              .slice(0, -1)
              .map((m) => ({ role: m.role, content: m.content })),
          }),
          signal: ctrl.signal,
        });

        if (!res.ok || !res.body) {
          let msg = `Request failed (${res.status}).`;
          try {
            const j = await res.json();
            if (j?.error) msg = j.error;
          } catch {
            /* ignore */
          }
          last.content = msg;
          last.error = true;
          return;
        }

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() ?? '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            let event: { type: string; [k: string]: unknown };
            try {
              event = JSON.parse(line.slice(6));
            } catch {
              continue;
            }
            if (event.type === 'sources') {
              last.sources = event.sources as SourceRef[];
            } else if (event.type === 'text') {
              last.content += event.text as string;
            } else if (event.type === 'error') {
              last.content = (event.error as string) || 'Something went wrong.';
              last.error = true;
            }
            render();
          }
        }
      } catch (err) {
        const isAbort = err instanceof DOMException && err.name === 'AbortError';
        if (!isAbort) {
          last.content = err instanceof Error ? err.message : 'Network error.';
          last.error = true;
        }
      } finally {
        isStreaming = false;
        render();
        inputEl.focus();
      }
    }

    sendBtn.addEventListener('click', () => {
      const v = inputEl.value;
      inputEl.value = '';
      send(v);
    });

    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        const v = inputEl.value;
        inputEl.value = '';
        send(v);
      }
    });

    suggestedEl.querySelectorAll<HTMLButtonElement>('[data-q]').forEach((btn) => {
      btn.addEventListener('click', () => send(btn.dataset.q ?? ''));
    });

    render();
  }
</script>
