---
type MetaProps = {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  /**
   * JSON-LD payload(s) injected as `<script type="application/ld+json">`.
   * Pass a single schema object or an array; will be JSON.stringified server-side.
   */
  structured?: object | object[];
};

const SITE_NAME = 'algoro.dev';
const DEFAULT_TITLE = 'algoro.dev | Senior AI Engineer';
const DEFAULT_DESCRIPTION =
  "Senior AI Engineer · production AI systems that ship, scale, and don't break.";
const DEFAULT_IMAGE = '/og-default.png';
const DEFAULT_IMAGE_ALT =
  'algoro.dev · Alejandro Gonzalez, Senior AI Engineer.';
const AUTHOR = 'Alejandro Gonzalez Romero';
const LOCALE = 'en_US';
const THEME_COLOR = '#08090b';

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  url = new URL(Astro.request.url, Astro.site).toString(),
  image = DEFAULT_IMAGE,
  imageAlt = DEFAULT_IMAGE_ALT,
  noindex = false,
  structured,
} = Astro.props as MetaProps;

const canonical = url;
const absoluteImage = new URL(image, Astro.site).toString();

const structuredArray = structured
  ? Array.isArray(structured)
    ? structured
    : [structured]
  : [];
---

<title>{title}</title>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<meta name="author" content={AUTHOR} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="theme-color" content={THEME_COLOR} />
<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={canonical} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/brand/algoro-icon.ico" sizes="any" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content={LOCALE} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={absoluteImage} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImage} />
<meta name="twitter:image:alt" content={imageAlt} />

{
  structuredArray.map((schema) => (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(schema)}
    />
  ))
}

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-VPQLS576ZE" is:inline></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-VPQLS576ZE');
</script>
