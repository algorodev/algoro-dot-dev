---
import BaseLayout from '@layouts/BaseLayout.astro';
import WorkCard from '@components/ui/WorkCard.astro';
import { getAllWork } from '@lib/content/work.ts';

const items = await getAllWork();

const title = 'Work — Alejandro Gonzalez';
const description = 'Case studies, projects, and ships across AI, e-commerce, enterprise, and self-hosted systems.';
---

<BaseLayout title={title} description={description}>
  <section class="container-x pt-24 pb-16 md:pt-[140px]">
    <div
      class="mb-8 flex flex-wrap items-center gap-4 font-mono text-xs tracking-[0.05em] text-fg-faded uppercase"
    >
      <span class="text-accent">● {items.length} entries</span>
      <span class="opacity-50">/</span>
      <span>case studies, projects, ships</span>
    </div>

    <h1
      class="mb-12 max-w-[1100px] font-serif font-normal leading-[0.95] tracking-[-0.03em]"
      style="font-size: clamp(52px, 8vw, 112px);"
    >
      Work.
    </h1>
  </section>

  <section class="container-x pb-32">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        items.map((it) => (
          <WorkCard
            href={`/work/${it.slug}`}
            tag={(it.tags ?? []).join(' · ')}
            period={it.year}
            title={it.title}
            description={it.summary}
            stack={it.stack ?? []}
            linkLabel={it.linkLabel ?? 'Read case study'}
            featured={!!it.featured}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
