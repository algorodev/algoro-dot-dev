---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import WorkCard from '@components/ui/WorkCard.astro';
import { getAllWork } from '@lib/content/work.ts';
import { breadcrumbsSchema, personSchema } from '@lib/seo.ts';

const items = await getAllWork();

const title = 'Work | Alejandro Gonzalez';
const description =
  'Case studies, projects, and ships across AI, e-commerce, enterprise, and self-hosted systems.';

const structured = [
  personSchema(),
  breadcrumbsSchema([
    { name: 'Home', url: '/' },
    { name: 'Work', url: '/work' },
  ]),
];
---

<BaseLayout title={title} description={description} structured={structured}>
  <Section
    bordered={false}
    number={`● ${items.length} entries`}
    eyebrow="case studies"
    meta="projects · ships"
    notes={['featured first', 'newest by default']}
    class="hero-section"
  >
    <h1
      class="mb-2 max-w-[1100px] font-serif font-normal leading-[0.95] tracking-[-0.03em]"
      style="font-size: clamp(52px, 8.5vw, 124px);"
    >
      Work.
    </h1>
  </Section>

  <Section bordered={false} number="/01" eyebrow="all work" meta={`${items.length} of ${items.length}`}>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        items.map((it) => (
          <WorkCard
            href={`/work/${it.slug}`}
            tag={(it.tags ?? []).join(' · ')}
            period={it.year}
            title={it.title}
            description={it.summary}
            stack={it.stack ?? []}
            linkLabel={it.linkLabel ?? 'Read case study'}
            featured={!!it.featured}
          />
        ))
      }
    </div>
  </Section>
</BaseLayout>

<style>
  .hero-section {
    padding-top: 120px;
    padding-bottom: 56px;
  }
  @media (max-width: 900px) {
    .hero-section {
      padding-top: 72px;
      padding-bottom: 32px;
    }
  }
</style>
