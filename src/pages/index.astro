---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/home/Hero.astro';
import TrustStrip from '@components/home/TrustStrip.astro';
import SelectedWork from '@components/home/SelectedWork.astro';
import AiDemo from '@components/home/AiDemo.astro';
import AboutSnippet from '@components/home/AboutSnippet.astro';
import TechGrid from '@components/home/TechGrid.astro';
import FooterCTA from '@components/home/FooterCTA.astro';
import { websiteSchema, personSchema } from '@lib/seo.ts';

const title = 'Alejandro Gonzalez | Senior AI Engineer';
const description =
  "Senior AI Engineer building production AI systems that ship, scale, and don't break. Hands-on with AI/ML in production since 2022.";

const structured = [websiteSchema(), personSchema()];
---

<BaseLayout title={title} description={description} structured={structured}>
  <section
    id="layer-surface"
    data-layer="surface"
    class="layer-section"
    style="background-color: var(--layer-surface-bg); color: var(--layer-surface-text);"
  >
    <Hero />
    <TrustStrip />
    <SelectedWork />
  </section>

  <section
    id="layer-mid"
    data-layer="mid"
    class="layer-section"
    style="background-color: var(--layer-mid-bg); color: var(--layer-mid-text);"
  >
    <div class="layer-descent">— descending into the stack —</div>
    <AboutSnippet />
    <TechGrid />
  </section>

  <section
    id="layer-deep"
    data-layer="deep"
    class="layer-section"
    style="background-color: var(--layer-deep-bg); color: var(--layer-deep-text);"
  >
    <div class="section section-bordered">
      <div class="section-rail">
        <span class="rail-num">/03</span>
        <span class="rail-eyebrow">infra &amp; systems</span>
        <div class="rail-divider"></div>
        <span class="rail-meta">coming soon</span>
      </div>
      <div class="section-content">
        <h2 class="section-title">Infra &amp; <em>Systems</em></h2>
      </div>
    </div>
  </section>

  <section
    id="layer-void"
    data-layer="void"
    class="layer-section"
    style="background-color: var(--layer-void-bg); color: var(--layer-void-text); min-height: auto;"
  >
    <AiDemo />
    <FooterCTA />
  </section>

  <div id="depth-indicator" aria-hidden="true">
    <span data-for="surface"></span>
    <span data-for="mid"></span>
    <span data-for="deep"></span>
    <span data-for="void"></span>
  </div>
</BaseLayout>

<style>
  .layer-descent {
    padding-top: 80px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--layer-mid-muted);
  }
</style>

<script>
  const layers = Array.from(document.querySelectorAll<HTMLElement>('[data-layer]'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('#depth-indicator [data-for]'));
  const root = document.documentElement;

  function setLayer(name: string) {
    const cs = getComputedStyle(root);
    root.style.setProperty('--active-layer', name);
    root.style.setProperty('--nav-bg', cs.getPropertyValue(`--layer-${name}-bg`).trim());
    root.style.setProperty('--nav-text', cs.getPropertyValue(`--layer-${name}-text`).trim());
    root.style.setProperty('--nav-accent', cs.getPropertyValue(`--layer-${name}-accent`).trim());

    layers.forEach((el) => el.classList.toggle('is-active', el.dataset.layer === name));
    dots.forEach((dot) => dot.classList.toggle('is-active', dot.getAttribute('data-for') === name));
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setLayer((entry.target as HTMLElement).dataset.layer!);
        }
      }
    },
    { rootMargin: '-40% 0px -40% 0px', threshold: 0 },
  );

  layers.forEach((el) => observer.observe(el));

  setLayer('surface');
</script>
