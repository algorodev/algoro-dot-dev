---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/home/Hero.astro';
import TrustStrip from '@components/home/TrustStrip.astro';
import SelectedWork from '@components/home/SelectedWork.astro';
import AiDemo from '@components/home/AiDemo.astro';
import AboutSnippet from '@components/home/AboutSnippet.astro';
import TechGrid from '@components/home/TechGrid.astro';
import FooterCTA from '@components/home/FooterCTA.astro';
import { websiteSchema, personSchema } from '@lib/seo.ts';

const title = 'Alejandro Gonzalez | Senior AI Engineer';
const description =
  "Senior AI Engineer building production AI systems that ship, scale, and don't break. Hands-on with AI/ML in production since 2022.";

const structured = [websiteSchema(), personSchema()];
---

<BaseLayout title={title} description={description} structured={structured}>
  <section
    id="layer-surface"
    data-layer="surface"
    class="layer-section"
    style="background-color: var(--layer-surface-bg); color: var(--layer-surface-text);"
  >
    <Hero />
    <TrustStrip />
    <SelectedWork />
  </section>

  <section
    id="layer-mid"
    data-layer="mid"
    class="layer-section"
    style="background-color: var(--layer-mid-bg); color: var(--layer-mid-text);"
  >
    <AboutSnippet />
    <TechGrid />
  </section>

  <section
    id="layer-deep"
    data-layer="deep"
    class="layer-section"
    style="background-color: var(--layer-deep-bg); color: var(--layer-deep-text);"
  >
    <div class="section section-bordered">
      <div class="section-rail">
        <span class="rail-num">/03</span>
        <span class="rail-eyebrow">infra &amp; systems</span>
        <div class="rail-divider"></div>
        <span class="rail-meta">coming soon</span>
      </div>
      <div class="section-content">
        <h2 class="section-title">Infra &amp; <em>Systems</em></h2>
      </div>
    </div>
  </section>

  <section
    id="layer-void"
    data-layer="void"
    class="layer-section"
    style="background-color: var(--layer-void-bg); color: var(--layer-void-text); min-height: auto;"
  >
    <AiDemo />
    <FooterCTA />
  </section>
</BaseLayout>
