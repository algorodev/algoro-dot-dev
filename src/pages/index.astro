---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/home/Hero.astro';
import TrustStrip from '@components/home/TrustStrip.astro';
import SelectedWork from '@components/home/SelectedWork.astro';
import AiDemo from '@components/home/AiDemo.astro';
import AboutSnippet from '@components/home/AboutSnippet.astro';
import TechGrid from '@components/home/TechGrid.astro';
import FooterCTA from '@components/home/FooterCTA.astro';
import { websiteSchema, personSchema } from '@lib/seo.ts';

const title = 'Alejandro Gonzalez | Senior AI Engineer';
const description =
  "Senior AI Engineer building production AI systems that ship, scale, and don't break. Hands-on with AI/ML in production since 2022.";

const structured = [websiteSchema(), personSchema()];

const deepProcesses = [
  { name: 'containerization', desc: 'Docker · AWS · multi-env' },
  { name: 'cloud-deployment', desc: 'Vercel · AWS · CI/CD pipelines' },
  { name: 'vector-storage', desc: 'pgvector · Qdrant · embeddings' },
  { name: 'self-hosted-llm', desc: 'Ollama · local runtime · legacy hw' },
  { name: 'data-pipelines', desc: 'ingestion · ETL · RAG indexing' },
  { name: 'api-design', desc: 'REST · NestJS · FastAPI · typed' },
];
---

<BaseLayout title={title} description={description} structured={structured}>
  <section
    id="layer-surface"
    data-layer="surface"
    class="layer-section"
    style="background-color: var(--layer-surface-bg); color: var(--layer-surface-text);"
  >
    <Hero />
    <TrustStrip />
    <SelectedWork />
  </section>

  <section
    id="layer-mid"
    data-layer="mid"
    class="layer-section"
    style="background-color: var(--layer-mid-bg); color: var(--layer-mid-text);"
  >
    <div class="layer-descent layer-fade-in">— descending into the stack —</div>
    <AboutSnippet />
    <TechGrid />
  </section>

  <section
    id="layer-deep"
    data-layer="deep"
    class="layer-section"
    style="background-color: var(--layer-deep-bg); color: var(--layer-deep-text);"
  >
    <div class="layer-descent layer-fade-in" style="color: var(--layer-deep-muted);">— going deeper —</div>

    <div class="section section-bordered deep-main" id="deep-content">
      <aside
        class="section-rail"
        style="color: var(--layer-deep-muted); border-color: var(--layer-deep-border);"
      >
        <div style="color: var(--layer-deep-accent); font-family: var(--font-mono); font-size: 12px;">/05</div>
        <div style="color: var(--layer-deep-text); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;">infra.sys</div>
        <div style="color: var(--layer-deep-muted); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;">deep layer</div>
      </aside>

      <div class="section-content">
        <div class="d-prompt">root@algoro:~$ ls -la /stack/infrastructure</div>
        <p class="d-prompt-output">The layer nobody sees. The one that matters most.</p>

        <div class="d-procs">
          {
            deepProcesses.map((p) => (
              <div class="d-proc-row">
                <span class="d-proc-left">
                  <span class="d-proc-dot">●</span>
                  <span class="d-proc-name">{p.name}</span>
                </span>
                <span class="d-proc-desc">{p.desc}</span>
              </div>
            ))
          }
        </div>

        <div class="d-otto">
          <div class="d-otto-status">● SELF-HOSTED · RUNNING</div>
          <h3 class="d-otto-title">Otto</h3>
          <p class="d-otto-desc">
            Personal AI assistant running on legacy hardware. Local LLM runtime via Ollama,
            RAG over my personal knowledge base, custom MCP integrations, and full vector
            storage — without sending a single token to the cloud.
          </p>
          <a href="/work/otto" class="d-otto-link">→ /work/otto — case study</a>
        </div>
      </div>
    </div>
  </section>

  <section
    id="layer-void"
    data-layer="void"
    class="layer-section"
    style="background-color: var(--layer-void-bg); color: var(--layer-void-text); min-height: auto; padding-bottom: 0;"
  >
    <div class="layer-void-signal layer-fade-in">— signal detected at depth 04 —</div>
    <AiDemo />
    <FooterCTA />
  </section>

  <div id="depth-indicator" aria-hidden="true">
    <span data-for="surface"></span>
    <span data-for="mid"></span>
    <span data-for="deep"></span>
    <span data-for="void"></span>
  </div>
</BaseLayout>

<style is:global>
  /* Home page only: set surface nav defaults before JS setLayer('surface') fires */
  html {
    --nav-bg: #f5f2ed;
    --nav-text: #1a1a18;
    --nav-accent: #c4622d;
  }
</style>

<style>
  .layer-descent {
    padding-top: 80px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--layer-mid-muted);
  }

  /* ── deep layer ── */

  .deep-main {
    border-top-color: var(--layer-deep-border);
    padding-bottom: 120px;
  }

  .d-prompt {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--layer-deep-accent);
    margin-bottom: 14px;
  }

  .d-prompt-output {
    font-size: 19px;
    line-height: 1.5;
    color: var(--layer-deep-text);
    max-width: 560px;
    margin-bottom: 48px;
  }

  /* process list */
  .d-procs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border: 1px solid var(--layer-deep-border);
    border-radius: 2px;
    background: color-mix(in srgb, var(--layer-deep-bg) 70%, black);
    overflow: hidden;
    margin-bottom: 64px;
  }
  .d-proc-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--layer-deep-border);
    border-right: 1px solid var(--layer-deep-border);
  }
  .d-proc-row:nth-child(even) {
    border-right: none;
  }
  .d-proc-row:nth-last-child(-n + 2) {
    border-bottom: none;
  }
  .d-proc-left {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-shrink: 0;
  }
  .d-proc-dot {
    font-size: 8px;
    color: var(--layer-deep-accent);
  }
  .d-proc-name {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--layer-deep-text);
  }
  .d-proc-desc {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--layer-deep-muted);
    text-align: right;
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .d-procs {
      grid-template-columns: 1fr;
    }
    .d-proc-row {
      border-right: none;
    }
    .d-proc-row:nth-last-child(-n + 2) {
      border-bottom: 1px solid var(--layer-deep-border);
    }
    .d-proc-row:last-child {
      border-bottom: none;
    }
  }

  /* otto spotlight */
  .d-otto {
    border-left: 2px solid var(--layer-deep-accent);
    padding-left: 32px;
  }
  .d-otto-status {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--layer-deep-accent);
    margin-bottom: 14px;
    animation: d-blink 1.5s ease infinite;
  }
  .d-otto-title {
    font-family: var(--font-serif);
    font-size: clamp(44px, 6vw, 80px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--layer-deep-text);
    margin-bottom: 20px;
  }
  .d-otto-desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--layer-deep-muted);
    max-width: 560px;
    margin-bottom: 20px;
  }
  .d-otto-link {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--layer-deep-accent);
    transition: opacity 0.2s ease;
  }
  .d-otto-link:hover {
    opacity: 0.7;
  }

  @keyframes d-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  /* ── void layer ── */

  .layer-void-signal {
    padding-top: 80px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--layer-void-muted);
    animation: signal-pulse 3s ease-in-out infinite;
  }

  @keyframes signal-pulse {
    0%,
    100% {
      letter-spacing: 0.06em;
    }
    50% {
      letter-spacing: 0.18em;
    }
  }
</style>

<script>
  const layers = Array.from(document.querySelectorAll<HTMLElement>('[data-layer]'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('#depth-indicator [data-for]'));
  const root = document.documentElement;

  const layerLabels: Record<string, string> = {
    surface: 'depth: 01 · surface',
    mid: 'depth: 02 · mid',
    deep: 'depth: 03 · deep',
    void: 'depth: 04 · void',
  };

  function setLayer(name: string) {
    const cs = getComputedStyle(root);
    root.style.setProperty('--active-layer', name);
    root.style.setProperty('--nav-bg', cs.getPropertyValue(`--layer-${name}-bg`).trim());
    root.style.setProperty('--nav-text', cs.getPropertyValue(`--layer-${name}-text`).trim());
    root.style.setProperty('--nav-accent', cs.getPropertyValue(`--layer-${name}-accent`).trim());

    const depthEl = document.getElementById('nav-depth');
    if (depthEl) depthEl.textContent = layerLabels[name] ?? name;

    layers.forEach((el) => el.classList.toggle('is-active', el.dataset.layer === name));
    dots.forEach((dot) => dot.classList.toggle('is-active', dot.getAttribute('data-for') === name));
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setLayer((entry.target as HTMLElement).dataset.layer!);
        }
      }
    },
    { rootMargin: '-40% 0px -40% 0px', threshold: 0 },
  );

  layers.forEach((el) => observer.observe(el));

  setLayer('surface');
</script>
