---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
---

<BaseLayout title="404 | algoro.dev" noindex>
  <section class="container-x py-32 text-center md:py-40">
    <div class="mb-8 font-mono text-[11px] tracking-[0.15em] text-fg-faded uppercase">
      error 404 · page not found
    </div>
    <h1
      class="mb-6 font-serif font-normal leading-[0.95] tracking-[-0.03em]"
      style="font-size: clamp(64px, 10vw, 140px);"
    >
      Page <em class="text-accent italic">not found.</em>
    </h1>
    <p class="mx-auto mb-12 max-w-[480px] text-[17px] text-fg-muted">
      The page you were looking for either moved, never existed, or got shipped to production
      somewhere else.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button href="/" variant="primary" arrow="→">Back home</Button>
      <Button href="/work" variant="secondary" arrow="→">View work</Button>
    </div>
  </section>
</BaseLayout>
