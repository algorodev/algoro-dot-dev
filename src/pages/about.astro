---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import StackTag from '@components/ui/StackTag.astro';
import Button from '@components/ui/Button.astro';
import { getProfile } from '@lib/content/profile.ts';
import { getAllExperiences } from '@lib/content/experience.ts';

const profile = await getProfile();
const experiences = await getAllExperiences();

const { name, role, raised, based, email, skills, image, Content } = profile;

const principles = [
  {
    label: '— principle / 01',
    title: 'Ship over prototype.',
    body: 'Production-grade from day one: observability, error handling, retries, evals. A demo that wows in a meeting but breaks at scale is not done — it has not started.',
  },
  {
    label: '— principle / 02',
    title: 'Architecture earns its keep.',
    body: 'Clean separation of concerns, typed boundaries, dependency injection where it pays. SOLID is a tool, not a religion. Tests exist to enable speed, not slow it down.',
  },
  {
    label: '— principle / 03',
    title: 'Instrument everything.',
    body: 'Centralised logging, structured analytics, performance budgets, AI evals. If a system is in production and you can\'t answer "is it working", it is not in production yet.',
  },
  {
    label: '— principle / 04',
    title: 'Product mindset.',
    body: 'Discover the real user problem, prototype quickly, iterate with data. The best engineering is invisible — it lets users get their job done without thinking about the code.',
  },
];

const title = 'About — Alejandro Gonzalez';
const description = `${role} based in ${based}. Senior AI Engineer with production track record across enterprise, scale-ups, and startups.`;
---

<BaseLayout title={title} description={description} image={image}>
  <Section
    bordered={false}
    number={`● ${role.toLowerCase()}`}
    eyebrow={`based in ${based.toLowerCase()}`}
    meta={`raised in ${raised.toLowerCase()}`}
    notes={['/ about', `${experiences.length} roles`, '2019 → today']}
    class="hero-section"
  >
    <h1
      class="mb-12 max-w-[1100px] font-serif font-normal leading-[0.95] tracking-[-0.03em]"
      style="font-size: clamp(52px, 8.5vw, 124px);"
    >
      About <em class="text-accent italic">{name.split(' ')[0].toLowerCase()}.</em>
    </h1>

    <div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-[1fr_1.5fr] lg:gap-16">
      <img
        src={image}
        alt={`Portrait of ${name}`}
        width="480"
        height="600"
        loading="eager"
        class="aspect-[4/5] w-full max-w-[420px] rounded-xl border border-border object-cover"
      />
      <div class="prose">
        <Content />
      </div>
    </div>
  </Section>

  <Section
    number="/01"
    eyebrow="trajectory"
    meta={`${experiences.length} roles`}
    notes={['oldest → newest reversed']}
    title="Trajectory"
  >
    <ol class="relative ml-2 grid gap-8 border-l border-border pl-8">
      {
        experiences.map((exp) => (
          <li class="relative">
            <span class="absolute -left-[37px] top-[10px] h-2.5 w-2.5 rounded-full bg-accent shadow-[0_0_8px_var(--color-accent)]" />
            <div class="mb-1 font-mono text-[11px] tracking-[0.1em] text-fg-faded uppercase">
              {exp.start} — {exp.end ?? 'present'} · {exp.location}
            </div>
            <h3 class="font-serif text-[28px] leading-tight font-normal tracking-[-0.02em]">
              {exp.title}
              {exp.organization && (
                <span class="text-fg-muted"> — {exp.organization}</span>
              )}
            </h3>
          </li>
        ))
      }
    </ol>
  </Section>

  <Section
    number="/02"
    eyebrow="how i work"
    meta="principles"
    title="How I work"
  >
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">
      {
        principles.map((p) => (
          <div>
            <div class="mb-3 font-mono text-[11px] tracking-[0.1em] text-fg-faded uppercase">
              {p.label}
            </div>
            <h3 class="mb-3 font-serif text-[28px] leading-tight font-normal tracking-[-0.02em]">
              {p.title}
            </h3>
            <p class="text-[15px] leading-[1.7] text-fg-muted">{p.body}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section
    number="/03"
    eyebrow="hands-on"
    meta="broader skills"
    title="Hands-on with"
  >
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_1.5fr] lg:gap-16">
      <p class="font-serif text-[24px] leading-[1.4] tracking-[-0.01em]">
        I bring a <em class="text-accent italic">product mindset</em> to senior IC and tech-lead
        roles — equally comfortable shaping systems, mentoring, or rolling up sleeves on the line.
      </p>
      <div class="flex flex-wrap gap-2">
        {skills.map((s: string) => <StackTag>{s}</StackTag>)}
      </div>
    </div>
  </Section>

  <section class="container-x border-t border-border py-32 text-center">
    <div
      class="mb-6 font-mono text-[11px] tracking-[0.15em] text-fg-faded uppercase"
    >
      — work together
    </div>
    <h2
      class="mb-6 font-serif font-normal leading-[0.95] tracking-[-0.03em]"
      style="font-size: clamp(48px, 7vw, 96px);"
    >
      Want to <em class="text-accent italic">work together?</em>
    </h2>
    <p class="mx-auto mb-10 max-w-[520px] text-[17px] text-fg-muted">
      Open to senior contracts and full-time roles. I respond within 24 hours.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button href="/contact" variant="primary" arrow="→">Get in touch</Button>
      <Button href={`mailto:${email}`} variant="secondary" arrow="→">{email}</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section {
    padding-top: 120px;
    padding-bottom: 80px;
  }
  @media (max-width: 900px) {
    .hero-section {
      padding-top: 72px;
      padding-bottom: 48px;
    }
  }
</style>
