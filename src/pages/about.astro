---
import BaseLayout from '@layouts/BaseLayout.astro';
import StackTag from '@components/ui/StackTag.astro';
import { getProfile } from '@lib/content/profile.ts';
import { getAllExperiences } from '@lib/content/experience.ts';
import { profilePageSchema, breadcrumbsSchema } from '@lib/seo.ts';

const profile = await getProfile();
const experiences = await getAllExperiences();

const { name, role, based, email, skills, image } = profile;

const principles = [
  {
    label: 'principle / 01',
    title: 'Ship over prototype.',
    body: 'Production-grade from day one: observability, error handling, retries, evals. A demo that wows in a meeting but breaks at scale is not done. It has not started.',
  },
  {
    label: 'principle / 02',
    title: 'Architecture earns its keep.',
    body: 'Clean separation of concerns, typed boundaries, dependency injection where it pays. SOLID is a tool, not a religion. Tests exist to enable speed, not slow it down.',
  },
  {
    label: 'principle / 03',
    title: 'Instrument everything.',
    body: "Centralised logging, structured analytics, performance budgets, AI evals. If a system is in production and you can't answer 'is it working', it is not in production yet.",
  },
  {
    label: 'principle / 04',
    title: 'Product mindset.',
    body: 'Discover the real user problem, prototype quickly, iterate with data. The best engineering is invisible: it lets users get their job done without thinking about the code.',
  },
];

const title = 'About | Alejandro Gonzalez';
const description = `${role} based in ${based}. Senior AI Engineer with a production track record across enterprise, scale-ups, and startups.`;

const structured = [
  profilePageSchema(),
  breadcrumbsSchema([
    { name: 'Home', url: '/' },
    { name: 'About', url: '/about' },
  ]),
];
---

<BaseLayout title={title} description={description} structured={structured}>
  <div class="ab-page">

    <!-- Blocks 1–3: Header, bio, quote -->
    <div class="ab-intro container-x">
      <img
        src={image}
        alt={`Portrait of ${name}`}
        width="88"
        height="88"
        loading="eager"
        class="ab-photo"
      />

      <div class="ab-eyebrow">// {role.toLowerCase()} · {based.toLowerCase()}</div>

      <h1 class="ab-title">
        About <em class="ab-accent">{name.split(' ')[0].toLowerCase()}.</em>
      </h1>

      <p class="ab-lead">
        Senior software engineer with <strong>nearly 8 years</strong> shipping production systems
        across enterprise (Mercedes-Benz), scale-ups (Smartbox), and startups. Hands-on with
        AI/ML in production since 2022. Currently CTO &amp; co-founder at Prozeso, building
        AI automation infrastructure for real businesses — not demos.
      </p>

      <p class="ab-bio">
        I work best at the intersection of product and engineering: scoping systems that will
        actually scale, shipping fast without accumulating debt, and making AI that earns trust
        by being observable, reliable, and honest about its limits.
      </p>

      <p class="ab-bio">
        Based in Valencia, Spain. Remote-first, CET&plusmn;4h. Available for senior contracts and
        full-time roles at AI-first companies.
      </p>

      <blockquote class="ab-quote">
        "Difficult many things are, but impossible nothing is."
      </blockquote>
    </div>

    <!-- Blocks 4–5: Trajectory label + timeline -->
    <div class="ab-section container-x ab-border">
      <div class="ab-section-label">
        // trajectory · {experiences.length} roles · 2019 → present
      </div>
      <ol class="ab-timeline">
        {
          experiences.map((exp) => (
            <li class="ab-timeline-item">
              <span class="ab-timeline-dot" aria-hidden="true"></span>
              <div class="ab-timeline-meta">
                {exp.start}–{exp.end ?? 'present'} · {exp.location}
              </div>
              <h3 class="ab-timeline-role">{exp.title}</h3>
              {exp.organization && (
                <div class="ab-timeline-org">{exp.organization}</div>
              )}
            </li>
          ))
        }
      </ol>
    </div>

    <!-- How I work -->
    <div class="ab-section container-x ab-border">
      <div class="ab-section-label">// how i work · principles</div>
      <h2 class="ab-section-title">How I work</h2>
      <div class="ab-principles">
        {
          principles.map((p) => (
            <div class="ab-principle">
              <div class="ab-principle-label">{p.label}</div>
              <h3 class="ab-principle-title">{p.title}</h3>
              <p class="ab-principle-body">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Hands-on -->
    <div class="ab-section container-x ab-border">
      <div class="ab-section-label">// hands-on · broader skills</div>
      <h2 class="ab-section-title">Hands-on with</h2>
      <p class="ab-skills-intro">
        I bring a <em class="ab-accent ab-italic">product mindset</em> to senior IC and tech-lead
        roles, equally comfortable shaping systems, mentoring, or rolling up sleeves on the line.
      </p>
      <div class="ab-tags">
        {skills.map((s: string) => <StackTag>{s}</StackTag>)}
      </div>
    </div>

    <!-- CTA -->
    <div class="ab-cta container-x ab-border">
      <div class="ab-cta-label">// contact</div>
      <a href={`mailto:${email}`} class="ab-cta-email">{email} →</a>
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Page shell ── */
  .ab-page {
    padding-top: 3rem;
    padding-bottom: 6rem;
  }

  .ab-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .ab-border {
    border-top: 1px solid var(--layer-mid-border);
  }

  /* ── Intro block ── */
  .ab-intro {
    padding-bottom: 0;
  }

  /* Block 2: Photo — avatar above text, not floated */
  .ab-photo {
    display: block;
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 2rem;
    border: 2px solid var(--layer-mid-border);
  }

  /* Block 1: Eyebrow */
  .ab-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--layer-mid-muted);
    margin-bottom: 1.5rem;
  }

  /* Block 1: Title */
  .ab-title {
    font-family: var(--font-serif);
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--layer-mid-text);
    margin-bottom: 2.5rem;
  }

  .ab-accent {
    color: var(--layer-mid-accent);
  }

  .ab-italic {
    font-style: italic;
  }

  /* Block 2: Lead paragraph */
  .ab-lead {
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.75;
    max-width: 52ch;
    color: var(--layer-mid-text);
    margin-bottom: 1.5rem;
  }

  .ab-lead strong {
    color: var(--layer-mid-text);
    font-weight: 600;
  }

  /* Block 2: Body bio paragraphs */
  .ab-bio {
    font-size: 16px;
    line-height: 1.8;
    color: var(--layer-mid-muted);
    max-width: 60ch;
    margin-bottom: 1.5rem;
  }

  /* Block 3: Quote */
  .ab-quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
    color: var(--layer-mid-accent);
    border-left: 2px solid var(--layer-mid-accent);
    padding-left: 1.5rem;
    margin: 3rem 0 0;
  }

  /* Block 4: Section label */
  .ab-section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--layer-mid-muted);
    margin-bottom: 2.5rem;
  }

  .ab-section-title {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 400;
    letter-spacing: -0.025em;
    color: var(--layer-mid-text);
    margin-bottom: 2.5rem;
  }

  /* Block 5: Timeline */
  .ab-timeline {
    display: grid;
    gap: 2rem;
    border-left: 1px solid var(--layer-mid-border);
    padding-left: 28px;
    margin-left: 6px;
  }

  .ab-timeline-item {
    position: relative;
  }

  .ab-timeline-dot {
    position: absolute;
    left: -35px;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--layer-mid-accent);
  }

  .ab-timeline-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--layer-mid-muted);
    margin-bottom: 0.25rem;
  }

  .ab-timeline-role {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--layer-mid-text);
    margin-bottom: 0.2rem;
  }

  .ab-timeline-org {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--layer-mid-accent);
  }

  /* Principles */
  .ab-principles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  @media (max-width: 640px) {
    .ab-principles {
      grid-template-columns: 1fr;
    }
  }

  .ab-principle-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--layer-mid-muted);
    margin-bottom: 0.5rem;
  }

  .ab-principle-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--layer-mid-text);
    margin-bottom: 0.6rem;
  }

  .ab-principle-body {
    font-size: 14px;
    line-height: 1.75;
    color: var(--layer-mid-muted);
  }

  /* Skills */
  .ab-skills-intro {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.6;
    letter-spacing: -0.01em;
    color: var(--layer-mid-muted);
    margin-bottom: 1.5rem;
    max-width: 52ch;
  }

  .ab-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* CTA */
  .ab-cta {
    padding-top: 3.5rem;
    padding-bottom: 2rem;
  }

  .ab-cta-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--layer-mid-muted);
    margin-bottom: 0.75rem;
  }

  .ab-cta-email {
    font-family: var(--font-serif);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 400;
    color: var(--layer-mid-accent);
    letter-spacing: -0.02em;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ab-cta-email:hover {
    opacity: 0.7;
  }
</style>
