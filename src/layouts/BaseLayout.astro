---
import '@styles/global.css';
import Meta from '@components/Meta.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';

type BaseLayoutProps = {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  structured?: object | object[];
};

const { title, description, url, image, imageAlt, noindex, structured } =
  Astro.props as BaseLayoutProps;

const isHome = Astro.url.pathname === '/';
const isContact = Astro.url.pathname === '/contact';
const isAbout = Astro.url.pathname === '/about';
---

<!doctype html>
<html lang="en">
  <head>
    <Meta
      title={title}
      description={description}
      url={url}
      image={image}
      imageAlt={imageAlt}
      noindex={noindex}
      structured={structured}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Plus+Jakarta+Sans:wght@400;500&family=Syne:wght@400;600;700&family=IBM+Plex+Sans:wght@400;500&family=Azeret+Mono:wght@400;600&family=Unbounded:wght@400;600;700&family=Space+Grotesk:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={[!isHome && 'standalone', isContact && 'contact-page', isAbout && 'about-page']}>
    <div id="home-stage">
      <Nav />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <div id="panel-overlay" aria-hidden="true">
      <div id="panel">
        <button id="panel-close" aria-label="Back to home">
          <span>← back</span>
        </button>
        <div id="panel-content"></div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var overlay = document.getElementById('panel-overlay');
        var panel = document.getElementById('panel');
        var panelContent = document.getElementById('panel-content');
        var panelClose = document.getElementById('panel-close');

        var homeScrollY = 0;

        var PANEL_ROUTES = ['/about', '/contact', '/work/otto', '/work/smartbox-voice', '/work/mercedes-ddx', '/work/prozeso-stack'];

        var LOADING_HTML = '<div class="panel-loading"><span class="panel-loading-bar"></span></div>';

        function getPanelType(url) {
          if (url.startsWith('/work/')) return 'work';
          if (url === '/contact') return 'contact';
          if (url === '/about') return 'about';
          return 'page';
        }

        function activatePanelContent() {
          // Re-execute any <script> tags injected via innerHTML (browsers skip them)
          panelContent.querySelectorAll('script').forEach(function (old) {
            var s = document.createElement('script');
            Array.from(old.attributes).forEach(function (a) { s.setAttribute(a.name, a.value); });
            s.textContent = old.textContent;
            old.parentNode.replaceChild(s, old);
          });

          // Activate reveal animations — IntersectionObserver from the source page
          // won't have observed these elements; mark them visible immediately
          panelContent.querySelectorAll('.reveal-up, .reveal-line').forEach(function (el) {
            el.classList.add('is-visible');
          });

          initContactForm();
        }

        function initContactForm() {
          var form = document.getElementById('contact-form');
          var successEl = document.getElementById('contact-success');
          var errorEl = document.getElementById('contact-error');
          if (!form || !successEl || !errorEl) return;
          if (form.dataset.initialized) return;
          form.dataset.initialized = 'true';

          var submitBtn = form.querySelector('button[type="submit"]');

          form.addEventListener('submit', function (e) {
            e.preventDefault();
            errorEl.classList.add('hidden');
            if (!form.reportValidity()) return;

            var data = Object.fromEntries(new FormData(form).entries());
            if (submitBtn) submitBtn.disabled = true;

            fetch('/api/contact', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            })
              .then(function (res) {
                if (!res.ok) {
                  return res.json().catch(function () { return null; }).then(function (body) {
                    errorEl.textContent = (body && body.error) || ('Request failed (' + res.status + ').');
                    errorEl.classList.remove('hidden');
                  });
                }
                form.classList.add('hidden');
                successEl.classList.remove('hidden');
              })
              .catch(function (err) {
                errorEl.textContent = (err && err.message) || 'Network error. Please try again.';
                errorEl.classList.remove('hidden');
              })
              .finally(function () {
                if (submitBtn) submitBtn.disabled = false;
              });
          });
        }

        async function loadPanelContent(url) {
          panel.dataset.panelType = getPanelType(url);
          panelContent.innerHTML = LOADING_HTML;
          try {
            var res = await fetch(url);
            var html = await res.text();
            var parser = new DOMParser();
            var doc = parser.parseFromString(html, 'text/html');
            var main = doc.querySelector('main');
            panelContent.innerHTML = main ? main.innerHTML : html;
          } catch (e) {
            panelContent.innerHTML = '<p style="padding:2rem">Error loading content.</p>';
          }
          activatePanelContent();
        }

        async function openPanel(url) {
          homeScrollY = window.scrollY;
          document.documentElement.style.setProperty('--scroll-y', homeScrollY + 'px');
          document.documentElement.style.overflow = 'hidden';
          document.body.classList.add('panel-open');

          await loadPanelContent(url);

          panel.scrollTop = 0;
          overlay.classList.add('is-open');
          overlay.setAttribute('aria-hidden', 'false');
          history.pushState({ panel: true, url: url }, '', url);
        }

        function closePanel() {
          overlay.classList.remove('is-open');
          overlay.setAttribute('aria-hidden', 'true');
          setTimeout(function () {
            document.documentElement.style.overflow = '';
            document.body.classList.remove('panel-open');
            document.documentElement.style.removeProperty('--scroll-y');
            window.scrollTo(0, homeScrollY);
            panelContent.innerHTML = '';
            delete panel.dataset.panelType;
          }, 580);
          history.pushState({}, '', '/');
        }

        panelClose.addEventListener('click', closePanel);

        window.addEventListener('popstate', function () {
          if (overlay.classList.contains('is-open')) closePanel();
        });

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && overlay.classList.contains('is-open')) closePanel();
        });

        // In-panel navigation: replace content instead of opening a nested panel
        document.addEventListener('click', function (e) {
          if (!overlay.classList.contains('is-open')) return;
          var link = e.target.closest('#panel-content a[href]');
          if (!link) return;
          var href = link.getAttribute('href');
          var url;
          try { url = new URL(href, window.location.origin); } catch (_) { return; }
          if (url.origin !== window.location.origin || link.target === '_blank' || link.hasAttribute('data-no-panel')) return;
          var shouldPanel = PANEL_ROUTES.some(function (r) {
            return url.pathname === r || url.pathname.startsWith('/work/');
          });
          if (!shouldPanel) return;
          e.preventDefault();
          loadPanelContent(url.pathname).then(function () {
            panel.scrollTop = 0;
            history.pushState({ panel: true, url: url.pathname }, '', url.pathname);
          });
        });

        // Outer interceptor: links outside the panel
        document.addEventListener('click', function (e) {
          var link = e.target.closest('a[href]');
          if (!link) return;
          if (link.closest('#panel')) return;

          var href = link.getAttribute('href');
          var url;
          try { url = new URL(href, window.location.origin); } catch (_) { return; }

          if (
            url.origin !== window.location.origin ||
            href.startsWith('#') ||
            link.target === '_blank' ||
            link.hasAttribute('data-no-panel')
          ) return;

          var shouldPanel = PANEL_ROUTES.some(function (r) {
            return url.pathname === r || url.pathname.startsWith('/work/');
          });

          if (shouldPanel) {
            e.preventDefault();
            openPanel(url.pathname);
          }
        });

        window.openPanel = openPanel;

        // Initialize contact form if present on standalone page load
        initContactForm();
      })();
    </script>
  </body>
</html>
