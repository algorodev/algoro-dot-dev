# Required: powers the build-time embedding pipeline and the live /api/chat endpoint.
GEMINI_API_KEY=

# Optional: enables sliding-window rate limiting on /api/chat (10 req/min/IP)
# and /api/contact (5 req/hour/IP). Without these the endpoints run unthrottled —
# only safe for local dev. Free tier at https://upstash.com is plenty for
# portfolio traffic.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required for /api/contact: contact form submissions are delivered as Telegram
# messages to your own chat. Create a bot via @BotFather to get the token, then
# message that bot once and call https://api.telegram.org/bot<TOKEN>/getUpdates
# to read your numeric chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
