# Required: powers the build-time embedding pipeline and the live /api/chat endpoint.
GEMINI_API_KEY=

# Optional: enables sliding-window rate limiting on /api/chat (10 req/min per IP).
# Without these the endpoint runs unthrottled — only safe for local dev.
# Free tier at https://upstash.com is plenty for portfolio traffic.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
