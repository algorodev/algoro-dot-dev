    "@tailwindcss/vite": "4.1.13",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "astro": "5.13.7",
    "tailwindcss": "4.1.13",
    "zod": "4.1.7"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@resvg/resvg-js": "^2.6.2",
    "eslint": "9.35.0",
    "eslint-plugin-astro": "1.3.1",
    "gray-matter": "^4.0.3",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.6.14",
